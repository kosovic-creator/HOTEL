{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@hotel/lib": ["packages/lib/index.ts"],
      "@hotel/ui": ["packages/ui/index.ts"],
      "@hotel/*": ["packages/*/index.ts"]
    },
    "target": "ES2017",
    "lib": ["ES2017", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "strict": true
  }
}
